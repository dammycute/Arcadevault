{
  "expo": {
    "name": "ArcadeVault",
    "slug": "ArcadeVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/game_icon.png",
    "scheme": "arcadevault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/game_icon.png",
        "backgroundImage": "./assets/images/game_icon.png",
        "monochromeImage": "./assets/images/game_icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.htcoding.ArcadeVault"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/game_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/game_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8257674d-f657-44d4-b0a3-e45a6f3d26be"
      }
    },
    "owner": "htcoding",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8257674d-f657-44d4-b0a3-e45a6f3d26be"
    }
  }
}